# Quizify - Root .gitignore
# This file intentionally lists generated files, secrets, local caches,
# and machine-specific artifacts that should never be committed.

# -----------------------------
# OS and editor files
# -----------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# -----------------------------
# Secrets and local env files
# -----------------------------
.env
.env.*
*.env
*.local
*.secret
*.secrets
backend/.env
frontend-mob/.env
frontend-web/.env
frontend-web/.env.local
frontend-web/.env.development.local
frontend-web/.env.test.local
frontend-web/.env.production.local

# Keys and certificates
*.pem
*.key
*.crt
*.p12
*.jks
*.keystore

# -----------------------------
# Logs and temporary artifacts
# -----------------------------
logs/
*.log
*.pid
*.out
*.err
*.tmp
*.temp

# -----------------------------
# Python (backend)
# -----------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.python-version
venv/
.venv/
env/
ENV/

# Build / packaging
build/
dist/
*.egg-info/
.eggs/

# Jupyter
.ipynb_checkpoints/

# -----------------------------
# Node / React (frontend-web)
# -----------------------------
frontend-web/node_modules/
frontend-web/dist/
frontend-web/.vite/
frontend-web/.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------
# Flutter / Dart (frontend-mob)
# -----------------------------
frontend-mob/.dart_tool/
frontend-mob/.flutter-plugins
frontend-mob/.flutter-plugins-dependencies
frontend-mob/.packages
frontend-mob/.metadata
frontend-mob/pubspec.lock
frontend-mob/build/
frontend-mob/coverage/
frontend-mob/flutter_*.png

# Flutter IDE files
frontend-mob/**/Generated.xcconfig
frontend-mob/**/flutter_export_environment.sh
frontend-mob/**/Flutter.podspec

# Android artifacts
frontend-mob/android/.gradle/
frontend-mob/android/captures/
frontend-mob/android/local.properties
frontend-mob/android/**/debug/
frontend-mob/android/**/profile/
frontend-mob/android/**/release/

# iOS/macOS CocoaPods and build outputs
frontend-mob/ios/Pods/
frontend-mob/ios/.symlinks/
frontend-mob/ios/Flutter/ephemeral/
frontend-mob/ios/Flutter/Generated.xcconfig
frontend-mob/ios/Flutter/flutter_export_environment.sh
frontend-mob/ios/ServiceDefinitions.json
frontend-mob/ios/Runner.xcworkspace/
frontend-mob/macos/Pods/
frontend-mob/macos/Flutter/ephemeral/

# Linux/Windows build outputs
frontend-mob/linux/flutter/ephemeral/
frontend-mob/windows/flutter/ephemeral/

# -----------------------------
# Supabase local/dev artifacts
# -----------------------------
supabase/.temp/
supabase/.branches/

# -----------------------------
# Project-specific generated/test output
# -----------------------------
test-output/
artifacts/
